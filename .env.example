# ── User profile (Mostafa references these in his system prompt) ──
MOSTAFA_USER_NAME="Your Name"
MOSTAFA_USER_SCHOOL="Your University"
MOSTAFA_USER_MAJOR="Your Major, Your Year"
MOSTAFA_USER_BACKGROUND="Python, JS, ML, automation. Built X and Y."

# ── Search defaults (override per-run with CLI flags too) ─────────
MOSTAFA_DEFAULT_CITY="Cairo"
MOSTAFA_DEFAULT_COUNTRY="Egypt"
MOSTAFA_DEFAULT_SEASON="summer"
MOSTAFA_DEFAULT_YEAR="2026"
MOSTAFA_MAX_AGE_DAYS="90"

# ── LinkedIn auth (optional but recommended) ──────────────────────
# Generate once with:
#   playwright codegen --save-storage=$HOME/.linkedin_auth.json https://www.linkedin.com/login
LINKEDIN_AUTH_PATH="$HOME/.linkedin_auth.json"

# ── Google Sheets output (optional) ───────────────────────────────
# Leave empty to skip Sheets and only get the local markdown report.
# To enable: create a Google Sheet, share it with your service account
# email, and set the ID below + place credentials.json in the repo root.
GOOGLE_SHEETS_ID=""
GOOGLE_CREDENTIALS_PATH="./credentials.json"
